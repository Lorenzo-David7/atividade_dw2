<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Timao</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/">
      <img class="brand-logo" src="/img/corinthians-logo.webp" alt="Logo do Corinthians">
      <span>Corinthians</span>
    </a>
    <nav class="nav" aria-label="Menu principal">
      <% menu.forEach((item) => { %>
        <a class="<%= active === item.href ? 'active' : '' %>" href="<%= item.href %>"><%= item.label %></a>
      <% }) %>
    </nav>
  </header>
  <main>
    <% if (erro) { %>
      <section class="notice error"><%= erro %></section>
    <% } %>
