<%- include("partials-header") %>

<section class="page-heading">
  <p class="eyebrow">Cadastro</p>
  <h1>Cadastre um torcedor</h1>
  <p>Os dados ficam salvos na tabela <strong>torcedores</strong> do MySQL.</p>
</section>

<section class="form-grid">
  <form class="form-card" action="/cadastro" method="POST">
    <% if (sucesso) { %>
      <p class="notice success">Cadastro realizado com sucesso.</p>
    <% } %>
    <label>
      Nome
      <input type="text" name="nome" placeholder="Nome do torcedor" required>
    </label>
    <label>
      Email
      <input type="email" name="email" placeholder="email@exemplo.com" required>
    </label>
    <label>
      Cidade
      <input type="text" name="cidade" placeholder="Sao Paulo" required>
    </label>
    <label>
      Jogador favorito
      <input type="text" name="jogador_favorito" placeholder="Ex: Socrates">
    </label>
    <button class="button primary" type="submit">Salvar cadastro</button>
  </form>

  <div class="table-wrap">
    <h2>Torcedores cadastrados</h2>
    <% if (torcedores.length === 0) { %>
      <p class="muted">Nenhum torcedor cadastrado ainda.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Nome</th>
            <th>Email</th>
            <th>Cidade</th>
            <th>Favorito</th>
          </tr>
        </thead>
        <tbody>
          <% torcedores.forEach((torcedor) => { %>
            <tr>
              <td><%= torcedor.nome %></td>
              <td><%= torcedor.email %></td>
              <td><%= torcedor.cidade %></td>
              <td><%= torcedor.jogador_favorito || "-" %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</section>

<%- include("partials-footer") %>
